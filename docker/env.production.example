# Template for /opt/zeno/.env on the Azure VM. Copy this there and fill in
# every placeholder below. This file is created by hand, once, and is never
# touched by CI/CD (it's excluded from the deploy workflow's file copy step).

APP_NAME=Zeno
INERTIA_SSR_ENABLED=false
APP_ENV=production
# Generate once locally with: php artisan key:generate --show
# Never rotate this casually - it invalidates all existing sessions/encrypted data.
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database (self-hosted MySQL, docker-compose.prod.yml "mysql" service) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=zeno
DB_USERNAME=zeno
DB_PASSWORD=
# Separate from DB_PASSWORD - used only by the mysql/db-backup containers for
# the root account. Generate a strong random value for both passwords.
DB_ROOT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- File storage: Cloudflare R2 (S3-compatible, ~free at this app's scale) ---
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=zeno-storage
AWS_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false
# The public URL files are served from - either R2's public r2.dev bucket URL,
# or a custom domain you've mapped to the bucket. Required for uploaded files
# (avatars, chat attachments) to actually be viewable in the browser.
AWS_URL=https://files.yourdomain.com

# --- Mail (Resend SMTP, free tier) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Reverb (WebSocket broadcasting) ---
REVERB_APP_ID=100001
# Must equal the REVERB_APP_KEY GitHub Actions repo VARIABLE (not secret) used
# at build time - this key is public (embedded in the frontend JS), only the
# secret below is actually sensitive.
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Internal docker-compose service name/port - the app talks to Reverb over the
# private backend network, not through the public domain.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# VITE_* values below are NOT read at runtime - they're baked into the frontend
# bundle at Docker build time via build-args (see .github/workflows/deploy.yml
# and the corresponding GitHub Actions repo variables: VITE_APP_NAME,
# VITE_REVERB_HOST, VITE_REVERB_PORT, VITE_REVERB_SCHEME, plus REVERB_APP_KEY
# reused as VITE_REVERB_APP_KEY). Kept here only for reference/consistency.
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=ws.yourdomain.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.yourdomain.com/auth/google/callback

# --- External MongoDB (e.g. Atlas) ---
MONGODB_URI=

GEMINI_API_KEY=

# --- Caddy (reverse proxy / automatic TLS - see Caddyfile) ---
APP_DOMAIN=app.yourdomain.com
REVERB_DOMAIN=ws.yourdomain.com
ACME_EMAIL=you@yourdomain.com
